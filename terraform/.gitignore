# ─── Terraform State Files ───────────────────────────────
# Contains sensitive info about your infrastructure
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# ─── Terraform Working Directory ─────────────────────────
# Auto-generated by terraform init, no need to commit
.terraform/
.terraform.lock.hcl

# ─── SSH Keys ────────────────────────────────────────────
# NEVER commit private or public keys
*.pem
*.pub
terra-key
project/terra-key
project/terra-key.pub

# ─── AWS Credentials ─────────────────────────────────────
# Never commit credentials
.aws/
credentials
*.credentials

# ─── Variable Files with Secrets ─────────────────────────
# These may contain passwords, tokens, secrets
*.tfvars
*.tfvars.json
# Exception - if you have example tfvars, allow it
!example.tfvars

# ─── OS Files ────────────────────────────────────────────
.DS_Store           # Mac
Thumbs.db           # Windows
desktop.ini

# ─── IDE Files ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Logs ────────────────────────────────────────────────
*.log
crash.log
crash.*.log

# ─── Override Files ──────────────────────────────────────
override.tf
override.tf.json
*_override.tf
*_override.tf.json
